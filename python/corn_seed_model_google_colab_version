import tensorflow as tf
from tensorflow.keras import layers, models, callbacks
from tensorflow.keras.preprocessing.image import ImageDataGenerator
from google.colab import drive
import pandas as pd
import os
import random
import shutil
import zipfile
import time



drive.mount('/content/drive')


from tensorflow.keras import mixed_precision
mixed_precision.set_global_policy('mixed_float16')



drive_zip_path = '/content/drive/MyDrive/CornSeedsDetectionSystem/CornDataExtracted.zip'
local_zip_path = '/content/CornDataExtracted.zip'
local_extract_dir = '/content/local_dataset2'

if not os.path.exists(local_extract_dir):
    print("🚀 Zip file not found locally. Copying from Google Drive...")
    if os.path.exists(drive_zip_path):
        start_time = time.time()
        shutil.copy(drive_zip_path, local_zip_path)
        print("📦 Unzipping to local high-speed storage...")
        with zipfile.ZipFile(local_zip_path, 'r') as zip_ref:
            zip_ref.extractall(local_extract_dir)
        os.remove(local_zip_path)
        print(f"✅ Unpack complete in {round(time.time() - start_time, 2)} seconds!")
    else:
        print(f"⚠️ Warning: Could not find {drive_zip_path}. Ensure your zip is in Drive.")

if os.path.exists(os.path.join(local_extract_dir, 'DataExtracted')):
    dataset_path = os.path.join(local_extract_dir, 'DataExtracted')
else:
    dataset_path = local_extract_dir

print(f"📂 Loading images from: {dataset_path}")



csv_path = '/content/drive/MyDrive/CornSeedsDetectionSystem/metadata.csv'
img_height, img_width = 224, 224


target_columns = [
    '1_peso', '5_peso', '10_peso', '20_peso',
    'old_type', 'new_type',
    'rusty', 'shiny', 'clean', 'darken', 'cracks'
]
num_classes = len(target_columns)



if not os.path.exists(csv_path):
    print("⚠️ metadata.csv not found. Creating a dummy file for testing...")
    image_files = [f for f in os.listdir(dataset_path) if f.lower().endswith(('.jpg', '.png', '.jpeg'))]
    dummy_data = {'filename': image_files}
    for col in target_columns:
        dummy_data[col] = [random.choice([0, 1]) for _ in range(len(image_files))]
    pd.DataFrame(dummy_data).to_csv(csv_path, index=False)

df = pd.read_csv(csv_path)
for col in target_columns:
    df[col] = df[col].astype(int)



datagen = ImageDataGenerator(rescale=1./255, validation_split=0.2)

train_datasets = datagen.flow_from_dataframe(
    dataframe=df,
    directory=dataset_path,
    x_col="filename",
    y_col=target_columns,
    target_size=(img_height, img_width),
    batch_size=256,
    class_mode='raw',
    subset='training',
    seed=123
)

validation_datasets = datagen.flow_from_dataframe(
    dataframe=df,
    directory=dataset_path,
    x_col="filename",
    y_col=target_columns,
    target_size=(img_height, img_width),
    batch_size=128,
    class_mode='raw',
    subset='validation',
    seed=123
)



from tensorflow.keras.applications import MobileNetV2
from tensorflow.keras.optimizers import Adam

data_augmentation = tf.keras.Sequential([
    layers.RandomFlip('horizontal_and_vertical'),
    layers.RandomRotation(0.2),
    layers.RandomZoom(0.1)
])

base_model = MobileNetV2(
    input_shape=(img_height, img_width, 3),
    include_top=False,
    weights='imagenet'
)
base_model.trainable = False

inputs = tf.keras.Input(shape=(img_height, img_width, 3))
x = data_augmentation(inputs)
x = tf.keras.applications.mobilenet_v2.preprocess_input(x * 255.0)
x = base_model(x, training=False)
x = layers.GlobalAveragePooling2D()(x)
x = layers.Dropout(0.4)(x)

outputs = layers.Dense(num_classes, activation='sigmoid', dtype='float32')(x)
model = models.Sequential([tf.keras.Model(inputs, outputs)])

model.compile(
    optimizer=Adam(learning_rate=0.001),
    loss=tf.keras.losses.BinaryCrossentropy(),
    metrics=['binary_accuracy']
)


checkpoint_dir = '/content/drive/MyDrive/CornSeedsDetectionSystem/checkpoints'
os.makedirs(checkpoint_dir, exist_ok=True)
checkpoint_path = os.path.join(checkpoint_dir, "model_epoch_{epoch:02d}.weights.h5")
csv_log_path = '/content/drive/MyDrive/CornSeedsDetectionSystem/training_history.csv'

cp_callback = callbacks.ModelCheckpoint(
    filepath=checkpoint_path,
    save_weights_only=True,
    save_best_only=False,
    verbose=1
)
csv_logger = callbacks.CSVLogger(csv_log_path, separator=',', append=True)

checkpoints = sorted([f for f in os.listdir(checkpoint_dir) if f.endswith('.weights.h5')])
initial_epoch = 0
if checkpoints:
    latest = checkpoints[-1]
    model.load_weights(os.path.join(checkpoint_dir, latest))
    initial_epoch = int(latest.split('_')[2].split('.')[0])
    print(f"\n🔄 Resuming from Epoch {initial_epoch}...")

model.fit(
    train_datasets,
    validation_data=validation_datasets,
    epochs=200,
    initial_epoch=initial_epoch,
    callbacks=[cp_callback, csv_logger]
)

model.save('/content/drive/MyDrive/CornSeedsDetectionSystem/multi_feature_corn_model_FINAL.keras')
print("🎉 Training Complete! Model saved to Drive!")